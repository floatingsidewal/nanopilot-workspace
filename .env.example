# NanoPilot agent configuration
# Default profile: Telegram + local LLM (Ollama) — see docs/ENV.md for other profiles.

# =========================================================================
# Required
# =========================================================================

# Pin the platform image. Use `latest` for develop / local testing; use a
# specific tag (e.g. `0.2.1`) in production.
NANOPILOT_VERSION=latest

# --- LLM backend (Ollama on the LXC / host, OpenAI-compatible /v1) ---
# Persona-container mode (default) reads COPILOT_PROVIDER_* vars forwarded
# directly into the container. Set all four together.
#
# Choose the right host for COPILOT_PROVIDER_BASE_URL:
#   Docker Desktop:   http://host.docker.internal:11434/v1
#   Linux bridge:     http://172.17.0.1:11434/v1
#   LAN-reachable:    http://192.168.x.x:11434/v1
COPILOT_PROVIDER_BASE_URL=http://host.docker.internal:11434/v1
COPILOT_PROVIDER_TYPE=openai
COPILOT_PROVIDER_API_KEY=ollama  # any non-empty string; Ollama ignores it
COPILOT_MODEL=llama3.1:8b        # must match a model you've `ollama pull`ed

# --- Telegram channel ---
# Get a token from @BotFather (/newbot in Telegram).
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user IDs. UNSET = bot is open to all.
# Get your ID from @userinfobot.
NANOPILOT_TELEGRAM_ALLOWLIST=

# =========================================================================
# Other profiles (uncomment what you need) — full reference: docs/ENV.md
# =========================================================================

# --- Profile C: GitHub Copilot instead of Ollama ---
# NANOPILOT_API_KEY=ghp_...                 # GitHub PAT with read:models scope
# (leave COPILOT_PROVIDER_BASE_URL / TYPE / API_KEY / MODEL unset — omitting them uses GitHub Models)
# COPILOT_MODEL=gpt-4o

# --- Profile D: Microsoft Teams channel ---
# MICROSOFT_APP_ID=
# MICROSOFT_APP_PASSWORD=
# MICROSOFT_APP_TYPE=SingleTenant
# MICROSOFT_APP_TENANT_ID=

# --- Tool execution (SSH, file ops) ---
# NANOPILOT_TOOL_EXECUTION=true

# --- Advanced ---
# NANOPILOT_LOG_LEVEL=debug              # trace/debug/info/warn/error/fatal
# NANOPILOT_REFLECTION_ENABLED=true
# NANOPILOT_TELEGRAM_GROUPS_ENABLED=true # respond in group chats, not just DMs
